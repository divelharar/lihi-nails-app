<!DOCTYPE html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />

    <title>Lihi Nails - זימון תורים</title>
    <meta name="description" content="האומנות שלי, הציפורניים שלך. קביעת תורים אונליין בקליק." />

    <!-- הגדרות במיוחד לווצאפ, פייסבוק ואינסטגרם (Open Graph) -->
    <meta property="og:title" content="Lihi Nails - זימון תורים 💅" />
    <meta property="og:description" content="האומנות שלי, הציפורניים שלך. היכנסי לקביעת תור בקליק! ✨" />
    <meta property="og:url" content="https://lihi-nails-app-8m7r.vercel.app/" />
    <meta property="og:type" content="website" />
    <!-- הלוגו של ליהיא לתצוגה המקדימה -->
    <meta property="og:image" content="https://i.postimg.cc/Vv1rnz74/Whats-App-Image-2026-04-30-at-13-03-12.jpg" />

    <!-- הגדרות האפליקציה (PWA) -->
    <meta name="theme-color" content="#db2777" />
    <link rel="manifest" href="/manifest.json" />

    <!-- הגדרות מיוחדות לאייפון (iOS) -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Lihi Nails" />
    <!-- הלוגו של ליהיא לאייפון -->
    <link rel="apple-touch-icon" href="https://i.postimg.cc/Vv1rnz74/Whats-App-Image-2026-04-30-at-13-03-12.jpg" />

    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <noscript>עליך לאפשר JavaScript כדי להשתמש באפליקציה זו.</noscript>
    <div id="root"></div>
  </body>
</html>
